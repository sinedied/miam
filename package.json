{
  "name": "miam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && biome ci . && vitest run && vite build"
  },
  "dependencies": {
    "lit": "^3.3.3",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.10.6",
    "marked": "^18.0.6",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
